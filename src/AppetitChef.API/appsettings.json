{
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=3306;Database=AppetitChefDb;User=root;Password=;CharSet=utf8mb4;"
  },
  "Jwt": {
    "Secret": "AppetitChef_Super_Secret_Key_2025_Minimo_32_Chars!",
    "Issuer": "AppetitChef",
    "Audience": "AppetitChefClients",
    "ExpiracaoMinutos": "480"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} - {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/appetitchef-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "AllowedOrigins": []
}
