{
  "ConnectionStrings": {
    "DefaultConnection": "Server=appetitchef.cqvq0eymuvb8.us-east-1.rds.amazonaws.com;Port=3306;Database=AppetitChefDb;User=admin;Password=appetitchef123456;CharSet=utf8mb4;SslMode=Required;SslCa=/certs/global-bundle.pem;AllowPublicKeyRetrieval=false;ConnectionTimeout=30;DefaultCommandTimeout=30;"
  },

  "JwtSettings": {
    "SecretKey": "AppetitChef_Super_Secret_Key_2025_Minimo_32_Chars!",
    "Issuer": "AppetitChef",
    "Audience": "AppetitChefClients",
    "ExpiresInSeconds": 28800
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} — {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/appetitchef-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {SourceContext} — {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },

  "AllowedHosts": "*",
  "AllowedOrigins": []
}